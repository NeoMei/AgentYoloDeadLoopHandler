{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "doom_loop": "ask",
    "bash": {
      "rm -rf /": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "dd if=* of=/dev/*": "deny",
      "mkfs": "deny",
      "shutdown": "deny",
      "reboot": "deny"
    }
  }
}
